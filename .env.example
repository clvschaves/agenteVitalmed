# ========================
# Google AI (Gemini)
# ========================
GOOGLE_API_KEY=sua_chave_aqui

# Modelos
GEMINI_FLASH_MODEL=gemini-1.5-flash
GEMINI_PRO_MODEL=gemini-1.5-pro
EMBEDDING_MODEL=text-embedding-004

# ========================
# PostgreSQL
# ========================
DATABASE_URL=postgresql+asyncpg://vitalmed:vitalmed123@postgres:5432/vitalmed_db
DATABASE_URL_SYNC=postgresql://vitalmed:vitalmed123@postgres:5432/vitalmed_db

# ========================
# Redis
# ========================
REDIS_URL=redis://redis:6379/0
JOB_TTL_SECONDS=300

# ========================
# Langfuse (self-hosted)
# ========================
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=http://langfuse:3000

# Preços dos modelos (USD por 1M tokens) — configurar no Langfuse também
GEMINI_FLASH_INPUT_PRICE=0.075
GEMINI_FLASH_OUTPUT_PRICE=0.30
GEMINI_PRO_INPUT_PRICE=1.25
GEMINI_PRO_OUTPUT_PRICE=5.00
EMBEDDING_INPUT_PRICE=0.025

# ========================
# Chatwoot
# ========================
CHATWOOT_API_URL=https://app.chatwoot.com
CHATWOOT_API_TOKEN=seu_token_aqui
CHATWOOT_ACCOUNT_ID=1

# Labels Chatwoot
CHATWOOT_LABEL_INTERESTED=interessado
CHATWOOT_LABEL_CLOSED=fechado
CHATWOOT_LABEL_ESCALATED=escalado_para_humano

# ========================
# Whisper (transcrição de vídeos)
# ========================
WHISPER_MODE=local
# local | openai_api
WHISPER_MODEL_SIZE=base
# tiny | base | small | medium | large
OPENAI_API_KEY=opcional_se_whisper_mode_openai_api

# ========================
# RAG
# ========================
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=0.20
RAG_TOP_K=5
RAG_MIN_SCORE=0.70
UPLOADS_DIR=./uploads

# ========================
# Aplicação
# ========================
APP_ENV=development
# development | production
APP_PORT=8000
LOG_LEVEL=INFO
